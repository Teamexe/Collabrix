{
  "name": "collab-edit",
  "displayName": "Collaborative Editing",
  "description": "Real-time collaborative code editing with CRDT-based synchronization, cursor presence, shared terminals, and Docker environments",
  "publisher": "vscode",
  "version": "1.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Teamexe/Collabrix.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:collab.createRoom",
    "onCommand:collab.joinRoom"
  ],
  "main": "./out/extension",
  "scripts": {
    "compile": "npx tsc -p ./",
    "watch": "npx tsc -watch -p ./",
    "test": "node ../../node_modules/mocha/bin/mocha out/test/**/*.test.js --timeout 10000"
  },
  "capabilities": {
    "virtualWorkspaces": false,
    "untrustedWorkspaces": {
      "supported": false
    }
  },
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "collabTasks",
          "name": "Team Tasks"
        }
      ]
    },
    "commands": [
      {
        "command": "collab.createRoom",
        "title": "Create Collaboration Room",
        "category": "Collab"
      },
      {
        "command": "collab.joinRoom",
        "title": "Join Collaboration Room",
        "category": "Collab"
      },
      {
        "command": "collab.leaveRoom",
        "title": "Leave Collaboration Room",
        "category": "Collab",
        "enablement": "collab.inRoom"
      },
      {
        "command": "collab.showUsers",
        "title": "Show Active Users",
        "category": "Collab",
        "enablement": "collab.inRoom"
      },
      {
        "command": "collab.openSharedTerminal",
        "title": "Open Shared Terminal",
        "category": "Collab",
        "enablement": "collab.inRoom"
      },
      {
        "command": "collab.assignPermission",
        "title": "Assign Collaboration Permissions",
        "category": "Collab",
        "enablement": "collab.inRoom"
      },
      {
        "command": "collab.showArchitecture",
        "title": "Collab: Show Architecture",
        "category": "Collab",
        "enablement": "collab.inRoom"
      },
      {
        "command": "collab.createTask",
        "title": "Collabrix: Create Task Ticket",
        "category": "Collab",
        "enablement": "collab.inRoom"
      },
      {
        "command": "collab.runDbQuery",
        "title": "Collabrix: Open Shared DB Explorer",
        "category": "Collab",
        "enablement": "collab.inRoom"
      },
      {
        "command": "collab.openBrowser",
        "title": "Collabrix: Open Synced Browser",
        "category": "Collab",
        "enablement": "collab.inRoom"
      },
      {
        "command": "collab.startHuddle",
        "title": "Collabrix: Start Voice Huddle",
        "category": "Collab"
      },
      {
        "command": "collab.assignToAI",
        "title": "Collabrix: Assign Task to AI",
        "category": "Collab",
        "enablement": "collab.inRoom"
      },
      {
        "command": "collab.checkpointTerminal",
        "title": "Collabrix: Save Terminal Checkpoint",
        "category": "Collab",
        "enablement": "collab.inRoom"
      },
      {
        "command": "collab.handoffTerminal",
        "title": "Collabrix: Restore Terminal Checkpoint (Handoff)",
        "category": "Collab",
        "enablement": "collab.inRoom"
      },
      {
        "command": "collab.showAuditLog",
        "title": "Collabrix: Show Audit Log",
        "category": "Collab",
        "enablement": "collab.inRoom"
      },
      {
        "command": "collab.prefetchDeps",
        "title": "Collabrix: Prefetch Dependencies",
        "category": "Collab"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "collab.assignToAI",
          "when": "view == collabTasks && viewItem == collabTask"
        }
      ]
    },
    "configuration": {
      "title": "Collaborative Editing",
      "properties": {
        "collab.serverUrl": {
          "type": "string",
          "default": "ws://localhost:4000",
          "description": "WebSocket URL of the collaboration server"
        },
        "collab.serverHttpUrl": {
          "type": "string",
          "default": "http://localhost:4000",
          "description": "HTTP URL of the collaboration server REST API"
        },
        "collab.userName": {
          "type": "string",
          "default": "",
          "description": "Your display name for collaboration sessions (auto-generated if empty)"
        },
        "collab.enableDocker": {
          "type": "boolean",
          "default": false,
          "description": "Enable Docker-based isolated environments for rooms"
        }
      }
    }
  },
  "dependencies": {
    "@vscode/vsce": "^3.7.1",
    "lib0": "^0.2.88",
    "uuid": "^9.0.0",
    "y-websocket": "^2.0.0",
    "yjs": "^13.6.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/uuid": "^9.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}
